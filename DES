# Simple DES-like encryption/decryption (no external libraries)

def encrypt(text, key):
    encrypted = ""

    for i in range(len(text)):
        # XOR each character with key
        enc_char = chr(ord(text[i]) ^ ord(key[i % len(key)]))
        encrypted += enc_char

    return encrypted


def decrypt(cipher, key):
    decrypted = ""

    for i in range(len(cipher)):
        # XOR again to reverse (same operation)
        dec_char = chr(ord(cipher[i]) ^ ord(key[i % len(key)]))
        decrypted += dec_char

    return decrypted


# ---------------- MAIN PROGRAM ----------------
if __name__ == "__main__":
    text = input("Enter the text: ")
    key = input("Enter the key: ")

    print("Original Text :", text)

    encrypted_text = encrypt(text, key)
    print("Encrypted Text:", encrypted_text)

    decrypted_text = decrypt(encrypted_text, key)
    print("Decrypted Text:", decrypted_text)
